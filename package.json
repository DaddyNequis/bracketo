{
  "name": "bracketo",
  "version": "0.1.0",
  "description": "React tournament bracket library powered by ReactFlow",
  "type": "module",
  "main": "./dist/bracketo.umd.js",
  "module": "./dist/bracketo.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/bracketo.es.js",
      "require": "./dist/bracketo.umd.js",
      "types": "./dist/index.d.ts"
    },
    "./style.css": "./dist/bracketo.css"
  },
  "files": ["dist"],
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.lib.json --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "@xyflow/react": ">=12.0.0"
  },
  "dependencies": {
    "zustand": "^5.0.0",
    "immer": "^10.0.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^2.5.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@xyflow/react": "^12.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^2.0.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/jest-dom": "^6.0.0",
    "jsdom": "^25.0.0"
  }
}
